<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="20dp"
        android:paddingBottom="40dp">

        <!-- Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/mirror_title"
            android:textColor="@color/colorAccent"
            android:textSize="26sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/mirror_subtitle"
            android:textColor="@color/colorTextSecondary"
            android:textSize="13sp"
            android:lineSpacingMultiplier="1.4"
            android:layout_marginBottom="28dp" />

        <!-- Your answer -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/mirror_your_answer_label"
            android:textColor="@color/colorTextSecondary"
            android:textSize="11sp"
            android:letterSpacing="0.12"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tv_mirror_your_answer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/colorSurface"
            android:padding="14dp"
            android:text=""
            android:textColor="@color/colorTextPrimary"
            android:textSize="14sp"
            android:lineSpacingMultiplier="1.5"
            android:layout_marginBottom="24dp" />

        <!-- VS divider -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="@color/colorBorder" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                android:text="vs"
                android:textColor="@color/colorTextSecondary"
                android:textSize="12sp" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="@color/colorBorder" />

        </LinearLayout>

        <!-- AI answer -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/mirror_ai_answer_label"
            android:textColor="@color/colorAccent"
            android:textSize="11sp"
            android:letterSpacing="0.12"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@color/colorSurface"
            android:layout_marginBottom="8dp">

            <View
                android:layout_width="3dp"
                android:layout_height="match_parent"
                android:background="@color/colorAccent" />

            <TextView
                android:id="@+id/tv_mirror_ai_answer"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:padding="14dp"
                android:text=""
                android:textColor="@color/colorTextPrimary"
                android:textSize="14sp"
                android:lineSpacingMultiplier="1.5" />

        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/colorBorder"
            android:layout_marginBottom="24dp" />

        <!-- Reflection -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="YOUR REFLECTION"
            android:textColor="@color/colorTextSecondary"
            android:textSize="11sp"
            android:letterSpacing="0.12"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Thinking through both gaps makes the comparison stick."
            android:textColor="@color/colorTextSecondary"
            android:textSize="12sp"
            android:layout_marginBottom="20dp" />

        <!-- Covered field -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/mirror_covered_label"
            android:textColor="@color/colorTextPrimary"
            android:textSize="13sp"
            android:textStyle="bold"
            android:lineSpacingMultiplier="1.3"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/et_mirror_covered"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="80dp"
            android:background="@color/colorSurface"
            android:gravity="top|start"
            android:hint="@string/mirror_covered_hint"
            android:inputType="textMultiLine|textCapSentences"
            android:padding="12dp"
            android:textColor="@color/colorTextPrimary"
            android:textColorHint="@color/colorTextSecondary"
            android:textSize="14sp"
            android:layout_marginBottom="20dp" />

        <!-- Missed field -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/mirror_missed_label"
            android:textColor="@color/colorTextPrimary"
            android:textSize="13sp"
            android:textStyle="bold"
            android:lineSpacingMultiplier="1.3"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/et_mirror_missed"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="80dp"
            android:background="@color/colorSurface"
            android:gravity="top|start"
            android:hint="@string/mirror_missed_hint"
            android:inputType="textMultiLine|textCapSentences"
            android:padding="12dp"
            android:textColor="@color/colorTextPrimary"
            android:textColorHint="@color/colorTextSecondary"
            android:textSize="14sp"
            android:layout_marginBottom="28dp" />

        <!-- Done button -->
        <Button
            android:id="@+id/btn_mirror_done"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/mirror_btn_done"
            android:layout_marginBottom="8dp" />

        <!-- Skip button -->
        <Button
            android:id="@+id/btn_mirror_skip"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/mirror_btn_skip"
            android:textColor="@color/colorTextSecondary"
            android:textSize="13sp"
            style="?attr/borderlessButtonStyle"
            android:layout_marginBottom="28dp" />

        <!-- ── AI Handoff — always shown at the end of the mirror ────────── -->
        <!-- This is the right place: student has just compared answers,      -->
        <!-- identified gaps, written reflections. They arrive here prepared. -->
        <LinearLayout
            android:id="@+id/ll_mirror_ai_handoff"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/colorSurface"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Header row with accent pip -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <View
                    android:layout_width="3dp"
                    android:layout_height="18dp"
                    android:layout_marginEnd="10dp"
                    android:background="@color/colorAccent" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Continue this conversation"
                    android:textColor="@color/colorTextPrimary"
                    android:textSize="14sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <!-- Explanation -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                android:lineSpacingMultiplier="1.4"
                android:text="You have done the work. Your attempt is already prepared as context — arrive at AI as a thinker, not as someone starting from zero."
                android:textColor="@color/colorTextSecondary"
                android:textSize="12sp" />

            <!-- Two AI buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btn_mirror_claude"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:text="Continue with Claude →"
                    android:textSize="12sp" />

                <Button
                    android:id="@+id/btn_mirror_chatgpt"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:backgroundTint="@color/colorBackground"
                    android:text="Continue with ChatGPT →"
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="12sp" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</ScrollView>