<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardBackgroundColor="@color/colorCardBackground"
    app:cardCornerRadius="10dp"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ── Top row: always visible ──────────────────────────────────── -->
        <LinearLayout
            android:id="@+id/ll_top_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:paddingEnd="16dp">

            <!-- Accent bar -->
            <View
                android:id="@+id/view_chapter_accent"
                android:layout_width="3dp"
                android:layout_height="44dp"
                android:background="@color/colorAccent" />

            <!-- Chapter number badge -->
            <TextView
                android:id="@+id/tv_chapter_number"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginStart="12dp"
                android:background="@color/colorSurface"
                android:gravity="center"
                android:text="1"
                android:textColor="@color/colorTextSecondary"
                android:textSize="12sp"
                android:textStyle="bold" />

            <!-- Chapter name + difficulty -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_chapter_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Chapter Name"
                    android:textColor="@color/colorTextPrimary"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_chapter_difficulty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Beginner"
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="11sp" />

            </LinearLayout>

            <!-- Status: → for available, ✓ for completed -->
            <TextView
                android:id="@+id/tv_chapter_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="→"
                android:textSize="18sp"
                android:textColor="@color/colorAccent" />

        </LinearLayout>

        <!-- ── Divider: shown only when completion row is visible ─────────── -->
        <View
            android:id="@+id/v_completion_divider"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/colorBorder"
            android:visibility="gone" />

        <!-- ── Completion row: visible only when chapter is done ─────────── -->
        <LinearLayout
            android:id="@+id/ll_completion_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="27dp"
            android:paddingEnd="8dp"
            android:paddingTop="8dp"
            android:paddingBottom="10dp"
            android:visibility="gone">

            <!-- Effort dot 1 -->
            <View
                android:id="@+id/dot_effort_1"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/bg_effort_dot"
                android:layout_marginEnd="4dp" />

            <!-- Effort dot 2 -->
            <View
                android:id="@+id/dot_effort_2"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/bg_effort_dot"
                android:layout_marginEnd="4dp" />

            <!-- Effort dot 3 -->
            <View
                android:id="@+id/dot_effort_3"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/bg_effort_dot"
                android:layout_marginEnd="10dp" />

            <!-- INDEPENDENT / HINT TIER X badge -->
            <TextView
                android:id="@+id/tv_completion_badge"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="INDEPENDENT"
                android:textSize="10sp"
                android:textColor="@color/colorCorrect"
                android:letterSpacing="0.05" />

            <!-- ↺ retake symbol — tappable -->
            <TextView
                android:id="@+id/btn_retake"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:gravity="center"
                android:text="↺"
                android:textSize="20sp"
                android:textColor="@color/colorAccent"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>