<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <!-- Subject label -->
    <TextView
        android:id="@+id/tv_subject_label"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="16dp"
        android:text="Subject"
        android:textColor="@color/colorAccent"
        android:textSize="11sp"
        android:textAllCaps="true"
        android:letterSpacing="0.12"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Task question -->
    <TextView
        android:id="@+id/tv_task_question"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:text="Task question will appear here."
        android:textColor="@color/colorTextPrimary"
        android:textSize="18sp"
        android:lineSpacingMultiplier="1.45"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_subject_label" />

    <!-- Answer EditText -->
    <EditText
        android:id="@+id/et_answer"
        android:layout_width="0dp"
        android:layout_height="130dp"
        android:layout_marginTop="16dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:background="@color/colorSurface"
        android:gravity="top|start"
        android:hint="Write your attempt here..."
        android:inputType="textMultiLine"
        android:padding="12dp"
        android:textColor="@color/colorTextPrimary"
        android:textColorHint="@color/colorTextSecondary"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_task_question" />

    <!-- Character count -->
    <TextView
        android:id="@+id/tv_char_count"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:layout_marginEnd="20dp"
        android:text="0 characters"
        android:textColor="@color/colorTextSecondary"
        android:textSize="11sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/et_answer" />

    <!-- ── Mic / Speech section ─────────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/ll_mic_section"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:background="@color/colorSurface"
        android:orientation="vertical"
        android:padding="12dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_char_count">

        <!-- Top row: mic button + status label + waveform -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/btn_mic"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@color/colorBackground"
                android:src="@android:drawable/ic_btn_speak_now"
                android:contentDescription="Speak your attempt"
                android:padding="8dp" />

            <TextView
                android:id="@+id/tv_recording_status"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:text="@string/task_record_start"
                android:textColor="@color/colorTextSecondary"
                android:textSize="12sp" />

            <!-- Animated waveform — hidden until listening starts -->
            <com.example.thinkfirst.WaveformView
                android:id="@+id/waveform_view"
                android:layout_width="50dp"
                android:layout_height="28dp"
                android:visibility="invisible" />

        </LinearLayout>

        <!-- Live partial transcription preview -->
        <TextView
            android:id="@+id/tv_transcription_preview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text=""
            android:textColor="@color/colorAccent"
            android:textSize="12sp"
            android:lineSpacingMultiplier="1.35"
            android:fontFamily="sans-serif-light"
            android:visibility="gone" />

    </LinearLayout>

    <!-- Effort level label -->
    <TextView
        android:id="@+id/tv_effort_label"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:text="@string/task_effort_label"
        android:textColor="@color/colorTextSecondary"
        android:textSize="11sp"
        android:textAllCaps="true"
        android:letterSpacing="0.12"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/ll_mic_section" />

    <!-- Effort progress bar -->
    <ProgressBar
        android:id="@+id/pb_effort"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="0dp"
        android:layout_height="8dp"
        android:layout_marginTop="6dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:max="3"
        android:progress="0"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_effort_label" />

    <!-- Effort hint label -->
    <TextView
        android:id="@+id/tv_effort_hint_label"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:text="Write or speak your attempt to unlock hints"
        android:textColor="@color/colorTextSecondary"
        android:textSize="12sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/pb_effort" />

    <!-- Get hint button -->
    <Button
        android:id="@+id/btn_get_hint"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:text="@string/task_hint_try_more"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_effort_hint_label" />

    <!-- Submit button -->
    <Button
        android:id="@+id/btn_submit"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:text="@string/task_btn_submit"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/btn_get_hint" />

    <!-- Detective mode button -->
    <Button
        android:id="@+id/btn_detective_mode"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:text="@string/task_btn_detective"
        android:alpha="0.35"
        android:enabled="false"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/btn_submit" />

</androidx.constraintlayout.widget.ConstraintLayout>