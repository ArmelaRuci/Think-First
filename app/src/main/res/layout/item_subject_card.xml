<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardBackgroundColor="@color/colorCardBackground"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="14dp"
        android:paddingBottom="14dp"
        android:paddingEnd="14dp">

        <!-- Left accent bar -->
        <View
            android:id="@+id/view_accent_bar"
            android:layout_width="3dp"
            android:layout_height="0dp"
            android:background="@color/colorAccent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Subject icon -->
        <ImageView
            android:id="@+id/iv_subject_icon"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginStart="14dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_subject_dsa"
            android:contentDescription="Subject icon"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@+id/view_accent_bar"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Subject name -->
        <TextView
            android:id="@+id/tv_subject_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="Subject Name"
            android:textColor="@color/colorTextPrimary"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@+id/tv_progress_badge"
            app:layout_constraintStart_toEndOf="@+id/iv_subject_icon"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toTopOf="@+id/tv_subject_description"
            app:layout_constraintVertical_chainStyle="packed" />

        <!-- Subject description -->
        <TextView
            android:id="@+id/tv_subject_description"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginTop="3dp"
            android:text="Description"
            android:textColor="@color/colorTextSecondary"
            android:textSize="12sp"
            android:lineSpacingMultiplier="1.3"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/tv_progress_badge"
            app:layout_constraintStart_toEndOf="@+id/iv_subject_icon"
            app:layout_constraintTop_toBottomOf="@+id/tv_subject_name" />

        <!-- Progress badge -->
        <TextView
            android:id="@+id/tv_progress_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@color/colorSurface"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:text="start"
            android:textColor="@color/colorTextSecondary"
            android:textSize="11sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.cardview.widget.CardView>