<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="40dp">

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="My Progress"
            android:textColor="@color/colorTextPrimary"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp" />

        <!-- ── Quick stats row ─────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="28dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:background="@color/colorSurface"
                android:orientation="vertical"
                android:padding="14dp">
                <TextView
                    android:id="@+id/tv_stat_tasks_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="@color/colorTextPrimary"
                    android:textSize="28sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="tasks done"
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="11sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="6dp"
                android:background="@color/colorSurface"
                android:orientation="vertical"
                android:padding="14dp">
                <TextView
                    android:id="@+id/tv_stat_hints_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="@color/colorTextPrimary"
                    android:textSize="28sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="hints asked"
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="11sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:background="@color/colorSurface"
                android:orientation="vertical"
                android:padding="14dp">
                <TextView
                    android:id="@+id/tv_stat_independence"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="@color/colorTankFull"
                    android:textSize="28sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="solo rate"
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="11sp" />
            </LinearLayout>

        </LinearLayout>

        <!-- ── Thinking independence ───────────────────────────────────── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="THINKING INDEPENDENCE"
            android:textColor="@color/colorTextSecondary"
            android:textSize="11sp"
            android:letterSpacing="0.12"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/colorSurface"
            android:padding="16dp"
            android:orientation="vertical"
            android:layout_marginBottom="28dp">

            <TextView
                android:id="@+id/tv_tank_percent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="50%"
                android:textColor="@color/colorTankFull"
                android:textSize="38sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Fills when you submit independently (+8%). \nDrains when you use hints (Tier 1: -5%, Tier 2: -10%, Tier 3: -20%)."
                android:textColor="@color/colorTextSecondary"
                android:textSize="11sp"
                android:lineSpacingMultiplier="1.35" />

        </LinearLayout>

        <!-- ── Subject performance ─────────────────────────────────────── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SUBJECT PERFORMANCE"
            android:textColor="@color/colorTextSecondary"
            android:textSize="13sp"
            android:letterSpacing="0.12"
            android:layout_marginBottom="6dp" />

        <TextView
            android:id="@+id/tv_chart_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Average effort score per subject (max 3.0)"
            android:textColor="@color/colorTextSecondary"
            android:textSize="12sp"
            android:layout_marginBottom="12dp" />

        <com.example.thinkfirst.BarChartView
            android:id="@+id/bar_chart_subjects"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="28dp" />

        <!-- ── Detective rank journey ──────────────────────────────────── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DETECTIVE RANK JOURNEY"
            android:textColor="@color/colorTextSecondary"
            android:textSize="11sp"
            android:letterSpacing="0.12"
            android:layout_marginBottom="12dp" />

        <!-- Rank progression strip — 5 cards injected programmatically -->
        <LinearLayout
            android:id="@+id/ll_rank_strip"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp" />

        <!-- Points to next rank + total -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/colorSurface"
            android:padding="14dp"
            android:orientation="vertical"
            android:layout_marginBottom="28dp">

            <TextView
                android:id="@+id/tv_detective_points"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 points total"
                android:textColor="@color/colorTextPrimary"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tv_detective_next_rank"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="@color/colorDetectiveGold"
                android:textSize="13sp" />

        </LinearLayout>

        <!-- ── Recent detective cases ──────────────────────────────────── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="RECENT CASES"
            android:textColor="@color/colorTextSecondary"
            android:textSize="11sp"
            android:letterSpacing="0.12"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:id="@+id/ll_recent_cases"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/colorSurface"
            android:orientation="vertical" />

    </LinearLayout>

</ScrollView>